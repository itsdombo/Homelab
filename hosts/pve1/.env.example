# Per-host config for pve1. Copy to .env (gitignored) and fill in real values.
# This file is loaded by tools/deploy.sh via `--env-file`, so anything here is
# available for ${VAR} interpolation in every service compose.
#
# Note: HOMELAB_HOST is set by the systemd unit (Environment=), not here —
# it decides *which* hosts/<name>/ dir this machine deploys.

# Your timezone — https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE="America/Vancouver"

# CurseForge API key for the gravitas2 Minecraft server (TYPE=AUTO_CURSEFORGE).
# Free key from https://console.curseforge.com/ (API Keys). Secret — keep it
# only in .env, never commit.
#
# Gotchas (see itzg/docker-minecraft-server#3591):
# - The key is a bcrypt string containing '$' (e.g. $2a$10$...). Compose reads
#   this via --env-file and interprets '$', so DOUBLE every dollar sign here:
#   $2a$10$...  ->  $$2a$$10$$...
# - If the API returns 403 even with a correct key, rename your CurseForge
#   organization in the console, regenerate the key, and try again. Verify
#   with the RAW key (single $, single-quoted):
#   curl -s -o /dev/null -w '%{http_code}\n' -H 'x-api-key: <raw key>' \
#     https://api.curseforge.com/v1/games        # want 200
CF_API_KEY=""
