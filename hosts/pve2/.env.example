# Per-host config for pve2. Copy to .env (gitignored) and fill in real values.
# This file is loaded by tools/deploy.sh via `--env-file`, so anything here is
# available for ${VAR} interpolation in every service compose.
#
# Note: HOMELAB_HOST is set by the systemd unit (Environment=), not here.
# It decides which hosts/<name>/ dir this machine deploys.

# Your timezone. See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE="America/Vancouver"

# Reverse proxy (Caddy) TLS via the Cloudflare DNS-01 challenge.
# ACME_EMAIL is the Let's Encrypt contact address.
# CLOUDFLARE_API_TOKEN is a scoped token with Zone:DNS:Edit on dominicrousseau.com.
ACME_EMAIL="contact@dominicrousseau.com"
CLOUDFLARE_API_TOKEN=""

# Cloudflare Tunnel connector token (Zero Trust → Networks → Tunnels).
# Outbound-only remote access; public hostnames are configured in the
# dashboard and must point at https://caddy:443, never at an app directly.
CLOUDFLARE_TUNNEL_TOKEN=""

# BookOrbit ebook library (services/bookorbit/README.md).
# Generate the three secrets with:
#   openssl rand -hex 24   → BOOKORBIT_POSTGRES_PASSWORD
#   openssl rand -hex 32   → BOOKORBIT_JWT_SECRET
#   openssl rand -hex 16   → BOOKORBIT_SETUP_BOOTSTRAP_TOKEN
BOOKORBIT_POSTGRES_PASSWORD=""
BOOKORBIT_JWT_SECRET=""
# One-time setup wizard token — needed for the first deploy only; blank it
# once the admin account exists.
BOOKORBIT_SETUP_BOOTSTRAP_TOKEN=""
# Public URL the app is reached at (it sits behind Caddy + the tunnel),
# never a localhost/LAN address.
BOOKORBIT_APP_URL="https://books.dominicrousseau.com"
# Local LXC storage paths (not SMB/NFS mounts), owned by PUID:PGID below.
# The dock dir is Book Dock's drop-a-file-here staging area; keep it separate
# from the library dir.
BOOKORBIT_BOOKS_PATH="/srv/bookorbit/books"
BOOKORBIT_DOCK_PATH="/srv/bookorbit/dock"
# uid/gid BookOrbit runs as; must own the two dirs above (check: `id deploy`).
PUID=1000
PGID=1000
# Basic Auth bcrypt hash from `docker exec -it caddy caddy hash-password`.
# KEEP THE SINGLE QUOTES — bcrypt hashes contain `$`, which compose would
# otherwise try to interpolate as a variable.
BOOKORBIT_BASIC_AUTH_HASH=''

# Wealthfolio investment tracker (services/wealthfolio/README.md).
# Secret key — encrypts stored API keys and signs logins. BACK IT UP:
# losing it means losing every encrypted secret the app has stored.
#   openssl rand -base64 32   → WEALTHFOLIO_SECRET_KEY
WEALTHFOLIO_SECRET_KEY=""
# Argon2id hash of the web login password. Generate on the host with:
#   printf '%s' 'your-password' | docker run --rm -i alpine sh -c \
#     "apk add -q argon2 && argon2 $(openssl rand -hex 8) -id -e"
# KEEP THE SINGLE QUOTES — the hash contains `$`, which compose would
# otherwise try to interpolate as a variable.
WEALTHFOLIO_AUTH_PASSWORD_HASH=''

# Immich photo library (services/immich/README.md).
# Postgres password — keep it alphanumeric (special characters can break the
# DB connection string):
#   openssl rand -hex 24   → IMMICH_DB_PASSWORD
IMMICH_DB_PASSWORD=""
# Local LXC storage path (not an SMB/NFS mount) holding originals, thumbnails,
# transcodes, and Immich's built-in DB dumps. Create it before the first
# deploy (see the README).
IMMICH_LIBRARY_PATH="/srv/immich/library"
