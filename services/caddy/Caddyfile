# Homelab reverse proxy.
#
# TLS certificates come from Let's Encrypt via the Cloudflare DNS-01 challenge,
# so nothing needs to be exposed to the internet on ports 80/443. Clients reach
# Caddy over the LAN or tailnet; Caddy proves domain control through Cloudflare's
# API using the token below.
#
# Required env (from hosts/<label>/.env, passed in by compose):
#   ACME_EMAIL            contact address for the Let's Encrypt account
#   CLOUDFLARE_API_TOKEN  scoped token, Zone:DNS:Edit on dominicrousseau.com
#
# Backends are reached by Docker service name because every include:'d service
# on a host shares one Compose project network (uptime-kuma, portainer, caddy).

{
	email {env.ACME_EMAIL}
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
}

kuma.dominicrousseau.com {
	reverse_proxy uptime-kuma:3001
}

portainer.dominicrousseau.com {
	# Portainer serves HTTPS on 9443 with its own self-signed cert, so tell Caddy
	# to trust the upstream. (Simpler alternative: proxy to http://portainer:9000
	# and delete the transport block, if Portainer's HTTP port stays enabled.)
	reverse_proxy https://portainer:9443 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}

books.dominicrousseau.com {
	# BookOrbit. Unlike the sites above this one is also published to the
	# internet through the Cloudflare Tunnel (cloudflared -> https://caddy:443),
	# so the whole site sits behind Basic Auth. The bcrypt hash comes from
	# `caddy hash-password` via the env, so no credential — not even a hash —
	# is committed to this public repo.
	#
	# Two exemptions, or the app cannot function behind Basic Auth:
	#  - /api/*: the frontend (and the KOReader plugin) send their own
	#    `Authorization: Bearer <jwt>` header on API calls, which replaces the
	#    Basic credentials — Caddy would 401 every API request the moment a
	#    user logs in. The API enforces BookOrbit's own auth on every route.
	#  - static assets: fetched anonymously (crossorigin, no Authorization),
	#    and a 401 on any re-triggers the browser's auth popup on every page
	#    load (seen with /topbar.png, /theme-init.js). App code and branding
	#    only, no user data.
	@protected not path /api/* *.js *.css *.png *.jpg *.svg *.ico *.woff *.woff2 *.map
	basic_auth @protected {
		dominic {env.BOOKORBIT_BASIC_AUTH_HASH}
	}
	reverse_proxy bookorbit:3000
}

money.dominicrousseau.com {
	# Wealthfolio. Tailnet/LAN-only — no Tunnel hostname, so this never sees
	# the internet. Auth is the app's own password login (Argon2id), so no
	# Basic Auth here; adding it would break the app's Bearer-token API calls
	# the same way it would BookOrbit's (see above).
	reverse_proxy wealthfolio:8088
}
